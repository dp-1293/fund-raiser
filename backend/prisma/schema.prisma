// Prisma Schema for FundRaise Pro Platform (MySQL 8)

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "linux-musl-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  CAMPAIGN_MANAGER
  NGO
  VOLUNTEER
  DONOR
  GUEST
}

enum CampaignStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
  ACTIVE
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum TaskStatus {
  OPEN
  ASSIGNED
  IN_PROGRESS
  COMPLETED
}

model User {
  id             String    @id @default(uuid())
  email          String    @unique
  passwordHash   String
  name           String
  avatar         String?
  phone          String?
  role           Role      @default(DONOR)
  isVerified     Boolean   @default(false)
  bio            String?   @db.Text
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  refreshTokens  RefreshToken[]
  campaigns      Campaign[]      @relation("OrganizerCampaigns")
  donations      Donation[]
  comments       Comment[]
  ngoProfile     NGOProfile?
  volunteerProfile VolunteerProfile?
  auditLogs      AuditLog[]
  notifications  Notification[]
  volunteerTasks VolunteerTask[] @relation("AssignedTasks")

  @@index([email])
  @@index([role])
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique @db.VarChar(500)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

model Category {
  id          String     @id @default(uuid())
  name        String     @unique
  slug        String     @unique
  description String?
  icon        String?
  campaigns   Campaign[]
}

model Campaign {
  id            String         @id @default(uuid())
  title         String
  slug          String         @unique
  summary       String         @db.Text
  story         String         @db.LongText
  targetAmount  Float
  raisedAmount  Float          @default(0.0)
  currency      String         @default("USD")
  categoryId    String
  category      Category       @relation(fields: [categoryId], references: [id])
  status        CampaignStatus @default(PENDING)
  isFeatured    Boolean        @default(false)
  isUrgent      Boolean        @default(false)
  featuredImage String
  gallery       Json?          // Array of image/video URLs
  videoUrl      String?
  organizerId   String
  organizer     User           @relation("OrganizerCampaigns", fields: [organizerId], references: [id])
  ngoId         String?
  ngo           NGOProfile?    @relation(fields: [ngoId], references: [id])
  startDate     DateTime       @default(now())
  endDate       DateTime
  location      String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  deletedAt     DateTime?

  donations     Donation[]
  updates       CampaignUpdate[]
  comments      Comment[]
  tasks         VolunteerTask[]

  @@index([categoryId])
  @@index([status])
  @@index([organizerId])
}

model Donation {
  id                String        @id @default(uuid())
  campaignId        String
  campaign          Campaign      @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  donorId           String?
  donor             User?         @relation(fields: [donorId], references: [id], onDelete: SetNull)
  donorName         String
  donorEmail        String
  amount            Float
  currency          String        @default("USD")
  isAnonymous       Boolean       @default(false)
  isRecurring       Boolean       @default(false)
  paymentGateway    String        // STRIPE, RAZORPAY, UPI
  transactionId     String        @unique
  status            PaymentStatus @default(SUCCESS)
  dedicationMessage String?       @db.Text
  createdAt         DateTime      @default(now())

  taxReceipt        TaxReceipt?

  @@index([campaignId])
  @@index([donorId])
  @@index([transactionId])
}

model TaxReceipt {
  id                    String   @id @default(uuid())
  donationId            String   @unique
  donation              Donation @relation(fields: [donationId], references: [id], onDelete: Cascade)
  receiptNumber         String   @unique
  pdfUrl                String?
  issueDate             DateTime @default(now())
  taxDeductibleAmount   Float
}

model CampaignUpdate {
  id         String   @id @default(uuid())
  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  title      String
  content    String   @db.Text
  createdAt  DateTime @default(now())
}

model Comment {
  id         String   @id @default(uuid())
  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  authorName String
  content    String   @db.Text
  createdAt  DateTime @default(now())
}

model NGOProfile {
  id                 String     @id @default(uuid())
  userId             String     @unique
  user               User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  orgName            String
  registrationNumber String     @unique
  taxId              String?
  address            String?    @db.Text
  phone              String?
  website            String?
  isVerified         Boolean    @default(false)
  documentsUrl       Json?
  createdAt          DateTime   @default(now())

  campaigns          Campaign[]
}

model VolunteerProfile {
  id           String   @id @default(uuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  skills       Json?    // Array of skills
  availability String?
  city         String?
  totalHours   Float    @default(0)
  badge        String   @default("Bronze Helper")
  createdAt    DateTime @default(now())
}

model VolunteerTask {
  id                  String     @id @default(uuid())
  campaignId          String
  campaign            Campaign   @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  title               String
  description         String     @db.Text
  assignedVolunteerId String?
  assignedVolunteer   User?      @relation("AssignedTasks", fields: [assignedVolunteerId], references: [id])
  status              TaskStatus @default(OPEN)
  hoursLogged         Float      @default(0)
  createdAt           DateTime   @default(now())
}

model VolunteerEvent {
  id          String   @id @default(uuid())
  title       String
  location    String
  eventDate   DateTime
  description String   @db.Text
  organizer   String
  createdAt   DateTime @default(now())
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  message   String   @db.Text
  type      String   @default("INFO")
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action    String
  entity    String
  entityId  String?
  details   String?  @db.Text
  ipAddress String?
  createdAt DateTime @default(now())
}

model NewsletterSubscriber {
  id           String   @id @default(uuid())
  email        String   @unique
  isSubscribed Boolean  @default(true)
  createdAt    DateTime @default(now())
}

model BlogPost {
  id          String   @id @default(uuid())
  title       String
  slug        String   @unique
  excerpt     String   @db.Text
  content     String   @db.LongText
  coverImage  String
  author      String
  category    String
  publishedAt DateTime @default(now())
}

model FAQ {
  id       String @id @default(uuid())
  question String
  answer   String @db.Text
  category String @default("General")
  order    Int    @default(0)
}
